{
  "openapi": "3.1.0",
  "info": {
    "title": "Little Echoes API",
    "version": "1.0.0-phase1",
    "description": "Normative product rules are in SPEC.md; this is the machine-readable HTTP contract."
  },
  "paths": {
    "/api/v1/recordings": {
      "post": {
        "operationId": "createRecording",
        "security": [
          {
            "deviceToken": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/RecordingUpload"
              }
            }
          }
        },
        "responses": {
          "201": {
            "$ref": "#/components/responses/RecordingCreated"
          },
          "200": {
            "$ref": "#/components/responses/RecordingCreated"
          },
          "400": {
            "$ref": "#/components/responses/Error"
          },
          "401": {
            "$ref": "#/components/responses/Error"
          },
          "409": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/api/v1/recordings/{recording_id}": {
      "get": {
        "operationId": "getRecording",
        "security": [
          {
            "deviceToken": []
          },
          {
            "accessJwt": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/RecordingId"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/Recording"
          },
          "401": {
            "$ref": "#/components/responses/Error"
          },
          "404": {
            "$ref": "#/components/responses/Error"
          }
        }
      },
      "delete": {
        "operationId": "deleteRecording",
        "security": [
          {
            "accessJwt": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/RecordingId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Version"
              }
            }
          }
        },
        "responses": {
          "202": {
            "$ref": "#/components/responses/AcceptedJob"
          },
          "409": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/api/v1/recordings/{recording_id}/process": {
      "post": {
        "operationId": "startAnalysis",
        "security": [
          {
            "deviceToken": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/RecordingId"
          }
        ],
        "responses": {
          "202": {
            "$ref": "#/components/responses/AcceptedJob"
          },
          "400": {
            "$ref": "#/components/responses/Error"
          },
          "403": {
            "$ref": "#/components/responses/Error"
          },
          "409": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/api/v1/recordings/{recording_id}/audio": {
      "get": {
        "operationId": "streamAudio",
        "security": [
          {
            "accessJwt": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/RecordingId"
          }
        ],
        "responses": {
          "200": {
            "description": "Authorized private WAV stream",
            "content": {
              "audio/wav": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Error"
          },
          "404": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/api/v1/recordings/{recording_id}/review": {
      "patch": {
        "operationId": "saveReview",
        "security": [
          {
            "accessJwt": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/RecordingId"
          }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/Review"
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/Recording"
          },
          "422": {
            "$ref": "#/components/responses/Error"
          },
          "403": {
            "$ref": "#/components/responses/Error"
          },
          "404": {
            "$ref": "#/components/responses/Error"
          },
          "409": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/api/v1/recordings/{recording_id}/approve": {
      "post": {
        "operationId": "approveRecording",
        "security": [
          {
            "accessJwt": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/RecordingId"
          }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/Review"
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/Recording"
          },
          "422": {
            "$ref": "#/components/responses/Error"
          },
          "403": {
            "$ref": "#/components/responses/Error"
          },
          "404": {
            "$ref": "#/components/responses/Error"
          },
          "409": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/api/v1/review-queue": {
      "get": {
        "operationId": "listReviewQueue",
        "security": [
          {
            "accessJwt": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/Limit"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/ReviewQueue"
          }
        }
      }
    },
    "/api/v1/diary": {
      "get": {
        "operationId": "listDiary",
        "security": [
          {
            "accessJwt": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/Limit"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/DiaryList"
          }
        }
      }
    },
    "/api/v1/diary/{diary_id}": {
      "patch": {
        "operationId": "editDiary",
        "security": [
          {
            "accessJwt": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/DiaryId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DiaryEdit"
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/Diary"
          },
          "409": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/api/v1/diary/{diary_id}/regenerate": {
      "post": {
        "operationId": "regenerateDiary",
        "security": [
          {
            "accessJwt": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/DiaryId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Version"
              }
            }
          }
        },
        "responses": {
          "202": {
            "$ref": "#/components/responses/AcceptedJob"
          },
          "409": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/api/v1/diary/{diary_id}/image": {
      "get": {
        "operationId": "streamDiaryImage",
        "security": [
          {
            "accessJwt": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/DiaryId"
          }
        ],
        "responses": {
          "200": {
            "description": "Authorized private image"
          },
          "404": {
            "$ref": "#/components/responses/Error"
          }
        }
      },
      "post": {
        "operationId": "generateDiaryImage",
        "security": [
          {
            "accessJwt": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/DiaryId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImageRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "$ref": "#/components/responses/AcceptedJob"
          },
          "409": {
            "$ref": "#/components/responses/Error"
          }
        }
      },
      "delete": {
        "operationId": "deleteDiaryImage",
        "security": [
          {
            "accessJwt": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/DiaryId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Version"
              }
            }
          }
        },
        "responses": {
          "202": {
            "$ref": "#/components/responses/AcceptedJob"
          }
        }
      }
    },
    "/api/v1/dictionary": {
      "get": {
        "operationId": "listDictionary",
        "security": [
          {
            "accessJwt": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/Limit"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/DictionaryList"
          }
        }
      }
    },
    "/api/v1/dictionary/{word_id}": {
      "get": {
        "operationId": "getDictionaryWord",
        "security": [
          {
            "accessJwt": []
          }
        ],
        "parameters": [
          {
            "name": "word_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^word_[A-Za-z0-9_-]+$"
            }
          },
          {
            "$ref": "#/components/parameters/Limit"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/DictionaryWord"
          },
          "404": {
            "$ref": "#/components/responses/Error"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "deviceToken": {
        "type": "http",
        "scheme": "bearer"
      },
      "accessJwt": {
        "type": "apiKey",
        "in": "header",
        "name": "Cf-Access-Jwt-Assertion"
      }
    },
    "parameters": {
      "RecordingId": {
        "name": "recording_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "pattern": "^rec_[A-Za-z0-9_-]+$"
        }
      },
      "DiaryId": {
        "name": "diary_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "pattern": "^diary_[A-Za-z0-9_-]+$"
        }
      },
      "Limit": {
        "name": "limit",
        "in": "query",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 20
        }
      }
    },
    "requestBodies": {
      "Review": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Review"
            }
          }
        }
      }
    },
    "responses": {
      "Error": {
        "description": "Safe machine-readable error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "AcceptedJob": {
        "description": "Durably accepted asynchronous job",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/AcceptedJob"
            }
          }
        }
      },
      "RecordingCreated": {
        "description": "Created or idempotently returned recording",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/RecordingCreated"
            }
          }
        }
      },
      "Recording": {
        "description": "Authorized recording state",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Recording"
            }
          }
        }
      },
      "RecordingList": {
        "description": "Bounded recording list",
        "content": {
          "application/json": {
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/Recording"
              }
            }
          }
        }
      },
      "ReviewQueue": {
        "description": "Bounded management review queue",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ReviewQueue"
            }
          }
        }
      },
      "DiaryList": {
        "description": "Bounded management diary list",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/DiaryList"
            }
          }
        }
      },
      "Diary": {
        "description": "Management diary entry",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Diary"
            }
          }
        }
      },
      "DictionaryList": {
        "description": "Bounded management dictionary list",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/DictionaryList"
            }
          }
        }
      },
      "DictionaryWord": {
        "description": "Management dictionary word with bounded history",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/DictionaryWord"
            }
          }
        }
      }
    },
    "schemas": {
      "Version": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "version"
        ],
        "properties": {
          "version": {
            "type": "integer",
            "minimum": 1
          }
        }
      },
      "RecordingUpload": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "audio",
          "client_capture_id",
          "captured_at",
          "captured_timezone",
          "pre_roll_seconds",
          "post_roll_seconds",
          "post_roll_truncated"
        ],
        "properties": {
          "audio": {
            "type": "string",
            "format": "binary",
            "contentMediaType": "audio/wav"
          },
          "client_capture_id": {
            "type": "string",
            "format": "uuid"
          },
          "captured_at": {
            "type": "string",
            "format": "date-time"
          },
          "captured_timezone": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          },
          "pre_roll_seconds": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10
          },
          "post_roll_seconds": {
            "type": "integer",
            "minimum": 0,
            "maximum": 5
          },
          "post_roll_truncated": {
            "type": "boolean"
          }
        }
      },
      "Review": {
        "type": "object",
        "additionalProperties": false,
        "required": ["version", "reviewed_text", "words", "captured_at", "captured_timezone"],
        "properties": {
          "version": {"type": "integer", "minimum": 1},
          "reviewed_text": {"type": "string", "maxLength": 2000},
          "words": {"type": "array", "maxItems": 30, "items": {"type": "object", "additionalProperties": false, "required": ["display_name", "normalized", "new_override"], "properties": {"display_name": {"type": "string", "minLength": 1, "maxLength": 100}, "normalized": {"type": "string", "minLength": 1, "maxLength": 100}, "new_override": {"enum": ["auto", "force_new", "force_not_new"]}}}},
          "captured_at": {"type": "string", "format": "date-time"},
          "captured_timezone": {"type": "string", "maxLength": 64},
          "scene": {"type": "string", "maxLength": 300},
          "parent_note": {"type": "string", "maxLength": 2000}
        }
      },
      "DiaryEdit": {
        "type": "object",
        "additionalProperties": false,
        "required": ["version", "diary_text"],
        "properties": {"version": {"type": "integer", "minimum": 1}, "diary_text": {"type": "string", "maxLength": 4000}}
      },
      "ImageRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["version"],
        "properties": {"version": {"type": "integer", "minimum": 1}, "replace_image_id": {"type": "string", "pattern": "^image_[A-Za-z0-9_-]+$"}}
      },
      "Error": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "message",
          "retryable",
          "correlation_id",
          "next_action"
        ],
        "properties": {
          "code": {
            "enum": [
              "UNAUTHORIZED",
              "FORBIDDEN",
              "NOT_FOUND",
              "VALIDATION_ERROR",
              "VERSION_CONFLICT",
              "IDEMPOTENCY_CONFLICT",
              "COST_LIMIT_REACHED",
              "DEMO_WRITE_DISABLED",
              "INVALID_REVIEW_INPUT",
              "REVIEW_NOT_AVAILABLE",
              "INVALID_LIMIT",
              "INVALID_MULTIPART",
              "INVALID_RECORDING_INPUT",
              "INVALID_DELETE_INPUT",
              "INVALID_WAV",
              "CONTENT_LENGTH_REQUIRED",
              "AUDIO_TOO_LARGE",
              "UNSUPPORTED_MEDIA_TYPE",
              "UPLOAD_IN_PROGRESS",
              "UPLOAD_RETRY_LIMIT_REACHED",
              "RECORDING_NOT_READY",
              "RECORDING_RESERVATION_FAILED",
              "RECORDING_STATE_UNAVAILABLE",
              "MEDIA_STORAGE_FAILED",
              "ALREADY_PROCESSED",
              "PROCESSING_STATE_UNAVAILABLE",
              "PROCESSING_ATTEMPT_LIMIT_REACHED",
              "PROCESSING_FAILED",
              "JOB_RESERVATION_FAILED",
              "WORKFLOW_DISPATCH_FAILED",
              "WORKFLOW_DISPATCH_UNKNOWN",
              "MOCK_ANALYSIS_FAILED",
              "STALE_ANALYSIS_JOB",
              "STALE_ANALYSIS_ATTEMPT",
              "DELETE_ATTEMPT_LIMIT_REACHED",
              "DELETE_RESERVATION_FAILED",
              "UPSTREAM_RESULT_UNKNOWN",
              "INTERNAL_ERROR",
              "IMAGE_REPLACEMENT_CONFIRMATION_REQUIRED"
            ]
          },
          "message": {
            "type": "string",
            "maxLength": 300
          },
          "retryable": {
            "type": "boolean"
          },
          "correlation_id": {
            "type": "string",
            "pattern": "^corr_[A-Za-z0-9_-]+$"
          },
          "next_action": {
            "type": "string",
            "maxLength": 300
          }
        }
      },
      "AcceptedJob": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "async_job_id",
          "status",
          "correlation_id"
        ],
        "properties": {
          "async_job_id": {
            "type": "string",
            "pattern": "^job_[A-Za-z0-9_-]+$"
          },
          "status": {
            "enum": [
              "dispatch_pending",
              "dispatched",
              "running"
            ]
          },
          "correlation_id": {
            "type": "string",
            "pattern": "^corr_[A-Za-z0-9_-]+$"
          }
        }
      },
      "RecordingCreated": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "recording_id",
          "analysis_status",
          "review_status",
          "version",
          "deduplicated",
          "correlation_id"
        ],
        "properties": {
          "recording_id": {
            "type": "string",
            "pattern": "^rec_[A-Za-z0-9_-]+$"
          },
          "analysis_status": {
            "$ref": "#/components/schemas/AnalysisStatus"
          },
          "review_status": {
            "$ref": "#/components/schemas/ReviewStatus"
          },
          "version": {
            "type": "integer",
            "minimum": 1
          },
          "deduplicated": {
            "type": "boolean"
          },
          "correlation_id": {
            "type": "string"
          }
        }
      },
      "Recording": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "recording_id",
          "analysis_status",
          "review_status",
          "version",
          "correlation_id"
        ],
        "properties": {
          "recording_id": {
            "type": "string",
            "pattern": "^rec_[A-Za-z0-9_-]+$"
          },
          "analysis_status": {
            "$ref": "#/components/schemas/AnalysisStatus"
          },
          "review_status": {
            "$ref": "#/components/schemas/ReviewStatus"
          },
          "version": {
            "type": "integer",
            "minimum": 1
          },
          "correlation_id": {
            "type": "string",
            "pattern": "^corr_[A-Za-z0-9_-]+$"
          },
          "async_job": {
            "$ref": "#/components/schemas/AcceptedJob"
          },
          "error": {
            "$ref": "#/components/schemas/Error"
          }
        }
      },
      "ReviewQueue": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "items",
          "failed_deletions",
          "correlation_id"
        ],
        "properties": {
          "items": {
            "type": "array",
            "maxItems": 100,
            "items": {
              "$ref": "#/components/schemas/ReviewQueueItem"
            }
          },
          "failed_deletions": {
            "type": "array",
            "maxItems": 20,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["recording_id", "captured_at", "captured_timezone", "version"],
              "properties": {
                "recording_id": {"type": "string", "pattern": "^rec_[A-Za-z0-9_-]+$"},
                "captured_at": {"type": "string", "format": "date-time"},
                "captured_timezone": {"type": "string", "maxLength": 64},
                "version": {"type": "integer", "minimum": 1}
              }
            }
          },
          "correlation_id": {
            "type": "string",
            "pattern": "^corr_[A-Za-z0-9_-]+$"
          }
        }
      },
      "ManagementRecording": {
        "type": "object",
        "additionalProperties": false,
        "required": ["recording_id", "analysis_status", "review_status", "captured_at", "captured_timezone", "captured_at_source", "source_type", "version", "correlation_id", "audio_endpoint"],
        "properties": {
          "recording_id": {"type": "string", "pattern": "^rec_[A-Za-z0-9_-]+$"},
          "analysis_status": {"$ref": "#/components/schemas/AnalysisStatus"},
          "review_status": {"$ref": "#/components/schemas/ReviewStatus"},
          "captured_at": {"type": "string", "format": "date-time"},
          "captured_timezone": {"type": "string", "maxLength": 64},
          "captured_at_source": {"enum": ["client_clock", "device_clock", "server_received", "manual"]},
          "source_type": {"enum": ["pc", "atom", "sample"]},
          "duration_seconds": {"type": "number", "exclusiveMinimum": 0, "maximum": 20},
          "pre_roll_seconds": {"type": "integer", "minimum": 0, "maximum": 10},
          "post_roll_seconds": {"type": "integer", "minimum": 0, "maximum": 5},
          "version": {"type": "integer", "minimum": 1},
          "correlation_id": {"type": "string", "pattern": "^corr_[A-Za-z0-9_-]+$"},
          "audio_endpoint": {"type": "string", "pattern": "^/api/v1/recordings/rec_[A-Za-z0-9_-]+/audio$"},
          "async_job": {"$ref": "#/components/schemas/AcceptedJob"},
          "error": {"$ref": "#/components/schemas/Error"}
        }
      },
      "ReviewQueueItem": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "recording",
          "transcript",
          "word_candidates",
          "scene",
          "parent_note"
        ],
        "properties": {
          "recording": {
            "$ref": "#/components/schemas/ManagementRecording"
          },
          "transcript": {
            "$ref": "#/components/schemas/Transcript"
          },
          "word_candidates": {
            "type": "array",
            "maxItems": 30,
            "items": {
              "$ref": "#/components/schemas/WordCandidate"
            }
          },
          "scene": {
            "type": ["string", "null"],
            "maxLength": 300
          },
          "parent_note": {
            "type": ["string", "null"],
            "maxLength": 2000
          }
        }
      },
      "Transcript": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "reviewed_text"
        ],
        "properties": {
          "raw_text": {
            "type": [
              "string",
              "null"
            ],
            "maxLength": 2000
          },
          "reviewed_text": {
            "type": [
              "string",
              "null"
            ],
            "maxLength": 2000
          },
          "language": {
            "type": [
              "string",
              "null"
            ],
            "maxLength": 32
          }
        }
      },
      "WordCandidate": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "display_name",
          "normalized",
          "is_new_candidate"
        ],
        "properties": {
          "display_name": {
            "type": "string",
            "maxLength": 100
          },
          "normalized": {
            "type": "string",
            "maxLength": 100
          },
          "part_of_speech": {
            "type": [
              "string",
              "null"
            ],
            "maxLength": 32
          },
          "is_new_candidate": {
            "type": "boolean"
          }
        }
      },
      "Diary": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "diary_id",
          "recording_id",
          "status",
          "captured_at",
          "new_words",
          "audio_endpoint",
          "version",
          "correlation_id"
        ],
        "properties": {
          "diary_id": {
            "type": "string",
            "pattern": "^diary_[A-Za-z0-9_-]+$"
          },
          "recording_id": {
            "type": "string",
            "pattern": "^rec_[A-Za-z0-9_-]+$"
          },
          "status": {
            "enum": [
              "not_started",
              "generating",
              "ready",
              "failed"
            ]
          },
          "captured_at": {"type": "string", "format": "date-time"},
          "new_words": {"type": "array", "maxItems": 30, "items": {"$ref": "#/components/schemas/WordOccurrence"}},
          "audio_endpoint": {"type": "string", "pattern": "^/api/v1/recordings/rec_[A-Za-z0-9_-]+/audio$"},
          "scene": {
            "type": [
              "string",
              "null"
            ],
            "maxLength": 300
          },
          "diary_text": {
            "type": [
              "string",
              "null"
            ],
            "maxLength": 4000
          },
          "active_image_id": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^image_[A-Za-z0-9_-]+$"
          },
          "version": {
            "type": "integer",
            "minimum": 1
          },
          "correlation_id": {
            "type": "string",
            "pattern": "^corr_[A-Za-z0-9_-]+$"
          }
        }
      },
      "DiaryList": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "items",
          "correlation_id"
        ],
        "properties": {
          "items": {
            "type": "array",
            "maxItems": 100,
            "items": {
              "$ref": "#/components/schemas/Diary"
            }
          },
          "correlation_id": {
            "type": "string",
            "pattern": "^corr_[A-Za-z0-9_-]+$"
          }
        }
      },
      "DictionaryWord": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "word_id",
          "display_name",
          "normalized",
          "occurrence_count",
          "history",
          "correlation_id"
        ],
        "properties": {
          "word_id": {
            "type": "string",
            "pattern": "^word_[A-Za-z0-9_-]+$"
          },
          "display_name": {
            "type": "string",
            "maxLength": 100
          },
          "normalized": {
            "type": "string",
            "maxLength": 100
          },
          "first_spoken_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "occurrence_count": {
            "type": "integer",
            "minimum": 0
          },
          "history": {
            "type": "array",
            "maxItems": 100,
            "items": {
              "$ref": "#/components/schemas/WordOccurrence"
            }
          },
          "correlation_id": {
            "type": "string",
            "pattern": "^corr_[A-Za-z0-9_-]+$"
          }
        }
      },
      "DictionaryList": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "items",
          "correlation_id"
        ],
        "properties": {
          "items": {
            "type": "array",
            "maxItems": 100,
            "items": {
              "$ref": "#/components/schemas/DictionaryWord"
            }
          },
          "correlation_id": {
            "type": "string",
            "pattern": "^corr_[A-Za-z0-9_-]+$"
          }
        }
      },
      "WordOccurrence": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "recording_id",
          "surface",
          "utterance_text",
          "spoken_at",
          "audio_endpoint",
          "is_first",
          "new_override"
        ],
        "properties": {
          "recording_id": {
            "type": "string",
            "pattern": "^rec_[A-Za-z0-9_-]+$"
          },
          "surface": {
            "type": "string",
            "maxLength": 100
          },
          "utterance_text": {
            "type": "string",
            "maxLength": 2000
          },
          "spoken_at": {
            "type": "string",
            "format": "date-time"
          },
          "is_first": {
            "type": "boolean"
          },
          "new_override": {
            "enum": [
              "auto",
              "force_new",
              "force_not_new"
            ]
          },
          "diary_id": {
            "type": ["string", "null"],
            "pattern": "^diary_[A-Za-z0-9_-]+$"
          },
          "audio_endpoint": {
            "type": "string",
            "pattern": "^/api/v1/recordings/rec_[A-Za-z0-9_-]+/audio$"
          }
        }
      },
      "AnalysisStatus": {
        "type": "string",
        "enum": [
          "pending",
          "transcribing",
          "extracting_words",
          "ready",
          "partial",
          "failed"
        ]
      },
      "ReviewStatus": {
        "type": "string",
        "enum": [
          "pending",
          "approved",
          "deleting",
          "delete_failed",
          "deleted"
        ]
      }
    }
  }
}
