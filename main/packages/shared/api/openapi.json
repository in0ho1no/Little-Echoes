{
  "openapi": "3.1.0",
  "info": { "title": "Little Echoes API", "version": "1.0.0-phase1", "description": "Normative product rules are in SPEC.md; this is the machine-readable HTTP contract." },
  "paths": {
    "/api/v1/recordings": { "post": { "operationId": "createRecording", "security": [{ "deviceToken": [] }], "requestBody": { "required": true, "content": { "multipart/form-data": { "schema": { "$ref": "#/components/schemas/RecordingUpload" } } } }, "responses": { "201": { "$ref": "#/components/responses/RecordingCreated" }, "200": { "$ref": "#/components/responses/RecordingCreated" }, "400": { "$ref": "#/components/responses/Error" }, "401": { "$ref": "#/components/responses/Error" }, "409": { "$ref": "#/components/responses/Error" } } } },
    "/api/v1/recordings/{recording_id}": { "get": { "operationId": "getRecording", "security": [{ "deviceToken": [] }, { "accessJwt": [] }], "parameters": [{ "$ref": "#/components/parameters/RecordingId" }], "responses": { "200": { "$ref": "#/components/responses/Recording" }, "401": { "$ref": "#/components/responses/Error" }, "404": { "$ref": "#/components/responses/Error" } } }, "delete": { "operationId": "deleteRecording", "security": [{ "accessJwt": [] }], "parameters": [{ "$ref": "#/components/parameters/RecordingId" }], "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Version" } } } }, "responses": { "202": { "$ref": "#/components/responses/AcceptedJob" }, "409": { "$ref": "#/components/responses/Error" } } } },
    "/api/v1/recordings/{recording_id}/process": { "post": { "operationId": "startAnalysis", "security": [{ "deviceToken": [] }], "parameters": [{ "$ref": "#/components/parameters/RecordingId" }], "responses": { "202": { "$ref": "#/components/responses/AcceptedJob" }, "400": { "$ref": "#/components/responses/Error" }, "403": { "$ref": "#/components/responses/Error" }, "409": { "$ref": "#/components/responses/Error" } } } },
    "/api/v1/recordings/{recording_id}/audio": { "get": { "operationId": "streamAudio", "security": [{ "accessJwt": [] }], "parameters": [{ "$ref": "#/components/parameters/RecordingId" }], "responses": { "200": { "description": "Authorized private WAV stream", "content": { "audio/wav": { "schema": { "type": "string", "format": "binary" } } } }, "401": { "$ref": "#/components/responses/Error" }, "404": { "$ref": "#/components/responses/Error" } } } },
    "/api/v1/recordings/{recording_id}/review": { "patch": { "operationId": "saveReview", "security": [{ "accessJwt": [] }], "parameters": [{ "$ref": "#/components/parameters/RecordingId" }], "requestBody": { "$ref": "#/components/requestBodies/Review" }, "responses": { "200": { "$ref": "#/components/responses/Recording" }, "409": { "$ref": "#/components/responses/Error" } } } },
    "/api/v1/recordings/{recording_id}/approve": { "post": { "operationId": "approveRecording", "security": [{ "accessJwt": [] }], "parameters": [{ "$ref": "#/components/parameters/RecordingId" }], "requestBody": { "$ref": "#/components/requestBodies/Review" }, "responses": { "202": { "$ref": "#/components/responses/AcceptedJob" }, "400": { "$ref": "#/components/responses/Error" }, "409": { "$ref": "#/components/responses/Error" } } } },
    "/api/v1/review-queue": { "get": { "operationId": "listReviewQueue", "security": [{ "accessJwt": [] }], "parameters": [{ "$ref": "#/components/parameters/Limit" }], "responses": { "200": { "$ref": "#/components/responses/RecordingList" } } } },
    "/api/v1/diary": { "get": { "operationId": "listDiary", "security": [{ "accessJwt": [] }], "parameters": [{ "$ref": "#/components/parameters/Limit" }], "responses": { "200": { "description": "Diary list" } } } },
    "/api/v1/diary/{diary_id}": { "patch": { "operationId": "editDiary", "security": [{ "accessJwt": [] }], "parameters": [{ "$ref": "#/components/parameters/DiaryId" }], "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DiaryEdit" } } } }, "responses": { "200": { "description": "Updated diary" }, "409": { "$ref": "#/components/responses/Error" } } } },
    "/api/v1/diary/{diary_id}/regenerate": { "post": { "operationId": "regenerateDiary", "security": [{ "accessJwt": [] }], "parameters": [{ "$ref": "#/components/parameters/DiaryId" }], "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Version" } } } }, "responses": { "202": { "$ref": "#/components/responses/AcceptedJob" }, "409": { "$ref": "#/components/responses/Error" } } } },
    "/api/v1/diary/{diary_id}/image": { "get": { "operationId": "streamDiaryImage", "security": [{ "accessJwt": [] }], "parameters": [{ "$ref": "#/components/parameters/DiaryId" }], "responses": { "200": { "description": "Authorized private image" }, "404": { "$ref": "#/components/responses/Error" } } }, "post": { "operationId": "generateDiaryImage", "security": [{ "accessJwt": [] }], "parameters": [{ "$ref": "#/components/parameters/DiaryId" }], "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ImageRequest" } } } }, "responses": { "202": { "$ref": "#/components/responses/AcceptedJob" }, "409": { "$ref": "#/components/responses/Error" } } }, "delete": { "operationId": "deleteDiaryImage", "security": [{ "accessJwt": [] }], "parameters": [{ "$ref": "#/components/parameters/DiaryId" }], "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Version" } } } }, "responses": { "202": { "$ref": "#/components/responses/AcceptedJob" } } } },
    "/api/v1/dictionary": { "get": { "operationId": "listDictionary", "security": [{ "accessJwt": [] }], "parameters": [{ "$ref": "#/components/parameters/Limit" }], "responses": { "200": { "description": "Dictionary list" } } } },
    "/api/v1/dictionary/{word_id}": { "get": { "operationId": "getDictionaryWord", "security": [{ "accessJwt": [] }], "parameters": [{ "name": "word_id", "in": "path", "required": true, "schema": { "type": "string", "pattern": "^word_[A-Za-z0-9_-]+$" } }], "responses": { "200": { "description": "Dictionary word and bounded history" }, "404": { "$ref": "#/components/responses/Error" } } } }
  },
  "components": {
    "securitySchemes": { "deviceToken": { "type": "http", "scheme": "bearer" }, "accessJwt": { "type": "apiKey", "in": "header", "name": "Cf-Access-Jwt-Assertion" } },
    "parameters": { "RecordingId": { "name": "recording_id", "in": "path", "required": true, "schema": { "type": "string", "pattern": "^rec_[A-Za-z0-9_-]+$" } }, "DiaryId": { "name": "diary_id", "in": "path", "required": true, "schema": { "type": "string", "pattern": "^diary_[A-Za-z0-9_-]+$" } }, "Limit": { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 20 } } },
    "requestBodies": { "Review": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Review" } } } } },
    "responses": { "Error": { "description": "Safe machine-readable error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }, "AcceptedJob": { "description": "Durably accepted asynchronous job", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AcceptedJob" } } } }, "RecordingCreated": { "description": "Created or idempotently returned recording", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RecordingCreated" } } } }, "Recording": { "description": "Authorized recording state", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Recording" } } } }, "RecordingList": { "description": "Bounded recording list", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Recording" } } } } } },
    "schemas": {
      "Version": { "type": "object", "additionalProperties": false, "required": ["version"], "properties": { "version": { "type": "integer", "minimum": 1 } } },
      "RecordingUpload": { "type": "object", "additionalProperties": false, "required": ["audio", "client_capture_id", "captured_at", "captured_timezone", "pre_roll_seconds", "post_roll_seconds", "post_roll_truncated"], "properties": { "audio": { "type": "string", "format": "binary", "contentMediaType": "audio/wav" }, "client_capture_id": { "type": "string", "format": "uuid" }, "captured_at": { "type": "string", "format": "date-time" }, "captured_timezone": { "type": "string", "minLength": 1, "maxLength": 64 }, "pre_roll_seconds": { "type": "integer", "minimum": 0, "maximum": 10 }, "post_roll_seconds": { "type": "integer", "minimum": 0, "maximum": 5 }, "post_roll_truncated": { "type": "boolean" } } },
      "Review": { "allOf": [{ "$ref": "#/components/schemas/Version" }, { "type": "object", "additionalProperties": false, "required": ["version", "reviewed_text", "words", "captured_at", "captured_timezone"], "properties": { "version": { "type": "integer", "minimum": 1 }, "reviewed_text": { "type": "string", "maxLength": 2000 }, "words": { "type": "array", "maxItems": 30, "items": { "type": "object", "additionalProperties": false, "required": ["display_name", "normalized", "new_override"], "properties": { "display_name": { "type": "string", "minLength": 1, "maxLength": 100 }, "normalized": { "type": "string", "minLength": 1, "maxLength": 100 }, "new_override": { "enum": ["auto", "force_new", "force_not_new"] } } } }, "captured_at": { "type": "string", "format": "date-time" }, "captured_timezone": { "type": "string", "maxLength": 64 }, "scene": { "type": "string", "maxLength": 300 }, "parent_note": { "type": "string", "maxLength": 2000 }, "generate_image": { "type": "boolean" } } }] },
      "DiaryEdit": { "allOf": [{ "$ref": "#/components/schemas/Version" }, { "type": "object", "additionalProperties": false, "required": ["version", "diary_text"], "properties": { "version": { "type": "integer", "minimum": 1 }, "diary_text": { "type": "string", "maxLength": 4000 } } }] },
      "ImageRequest": { "allOf": [{ "$ref": "#/components/schemas/Version" }, { "type": "object", "additionalProperties": false, "required": ["version"], "properties": { "version": { "type": "integer", "minimum": 1 }, "replace_image_id": { "type": "string", "pattern": "^image_[A-Za-z0-9_-]+$" } } }] },
      "Error": { "type": "object", "additionalProperties": false, "required": ["code", "message", "retryable", "correlation_id", "next_action"], "properties": { "code": { "enum": ["UNAUTHORIZED", "FORBIDDEN", "NOT_FOUND", "VALIDATION_ERROR", "VERSION_CONFLICT", "IDEMPOTENCY_CONFLICT", "COST_LIMIT_REACHED", "DEMO_WRITE_DISABLED", "UPSTREAM_RESULT_UNKNOWN", "IMAGE_REPLACEMENT_CONFIRMATION_REQUIRED"] }, "message": { "type": "string", "maxLength": 300 }, "retryable": { "type": "boolean" }, "correlation_id": { "type": "string", "pattern": "^corr_[A-Za-z0-9_-]+$" }, "next_action": { "enum": ["none", "reload", "poll", "retry", "manual_edit", "contact_owner"] } } },
      "AcceptedJob": { "type": "object", "additionalProperties": false, "required": ["async_job_id", "status", "correlation_id"], "properties": { "async_job_id": { "type": "string", "pattern": "^job_[A-Za-z0-9_-]+$" }, "status": { "enum": ["dispatch_pending", "dispatched", "running"] }, "correlation_id": { "type": "string", "pattern": "^corr_[A-Za-z0-9_-]+$" } } },
      "RecordingCreated": { "type": "object", "additionalProperties": false, "required": ["recording_id", "analysis_status", "review_status", "version", "deduplicated", "correlation_id"], "properties": { "recording_id": { "type": "string", "pattern": "^rec_[A-Za-z0-9_-]+$" }, "analysis_status": { "$ref": "#/components/schemas/AnalysisStatus" }, "review_status": { "$ref": "#/components/schemas/ReviewStatus" }, "version": { "type": "integer", "minimum": 1 }, "deduplicated": { "type": "boolean" }, "correlation_id": { "type": "string" } } },
      "Recording": { "allOf": [{ "$ref": "#/components/schemas/RecordingCreated" }, { "type": "object", "properties": { "async_job": { "$ref": "#/components/schemas/AcceptedJob" }, "error": { "$ref": "#/components/schemas/Error" } } }] },
      "AnalysisStatus": { "type": "string", "enum": ["pending", "transcribing", "extracting_words", "ready", "partial", "failed"] },
      "ReviewStatus": { "type": "string", "enum": ["pending", "approved", "deleting", "delete_failed", "deleted"] }
    }
  }
}
